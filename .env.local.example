# Convex deployment URL (from `npx convex dev`)
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Set these in Convex dashboard > Settings > Environment Variables:
# AUTH_GOOGLE_ID=your-google-client-id
# AUTH_GOOGLE_SECRET=your-google-client-secret
# AI_VPS_URL=https://your-python-vps.example.com   (leave unset for mock mode)
# AI_VPS_SECRET=your-vps-secret
